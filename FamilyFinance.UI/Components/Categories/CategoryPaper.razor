<MudPaper Elevation="3" Class="pa-4 mb-3 position-relative">
    @if (isEditMode)
    {
        <MudTextField Label="Название коллекции"
                      @bind-Value="newCategoryName"
                      Variant="Variant.Outlined" Immediate
                      Class="mb-4" AutoFocus Required
                      OnKeyDown="HandleKeyDown" />
        
        <MudNumericField Label="Месячный план" Required
                         @bind-Value="newCategoryMonthlyPlan"
                         Variant="Variant.Outlined" Immediate
                         Class="mb-4" Min="0"
                         OnKeyDown="HandleKeyDown" />
        
        <MudTextField Label="Вспомогательное слово"
                      @bind-Value="auxiliaryWord"
                      Variant="Variant.Outlined"
                      Immediate Class="mb-4"
                      OnKeyDown="HandleKeyDownForAuxiliaryWord" />
        
        <MudButton Variant="Variant.Filled"
                   OnClick="AddAuxiliaryWord"
                   Disabled="@(auxiliaryWord.IsEmpty())"
                   Class="mb-4" Color="Color.Primary">
            Добавить
        </MudButton>
        
        if (auxiliaryWords.Count > 0)
        {
            <MudText>
                Вспомогательные слова:
            </MudText>
            <div>
                @foreach (var word in auxiliaryWords)
                {
                    <MudChip T="string" @key="word" Variant="Variant.Text"
                             Color="Color.Primary"
                             CloseIcon="@Icons.Material.Filled.Delete"
                             OnClose="@(() => RemoveAuxiliaryWord(word))">
                        @word
                    </MudChip>
                }
            </div>
        }

        <MudStack Row AlignItems="AlignItems.Center">
            <MudButton OnClick="UnsetAndClearUpdateMode"
                       Color="Color.Primary" Variant="Variant.Outlined">
                Отменить
            </MudButton>
                    
            <MudSpacer />
                    
            <MudButton OnClick="SaveAsync"
                       Disabled="IsSaveButtonDisabled"
                       Color="Color.Primary" Variant="Variant.Filled">
                Сохранить
            </MudButton>
        </MudStack>
                
        if (isUpdateLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="isUpdateLoading"
                               Class="mt-2" />
        }
    }
    else
    {
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">
                @Category.Name
            </MudText>
            <MudText>
                Месячный план: @Category.MonthlyPlan.FormatRubles()
            </MudText>
        </MudStack>
        <div class="menu-position">
            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense>
                <MudMenuItem OnClick="SetUpdateMode" IconColor="Color.Primary"
                             Icon="@Icons.Material.Filled.Edit">
                    Редактировать
                </MudMenuItem>
                <MudMenuItem OnClick="DeleteAsync" IconColor="Color.Error"
                             Icon="@Icons.Material.Filled.Delete">
                    Удалить
                </MudMenuItem>
            </MudMenu>
        </div>
    }
</MudPaper>