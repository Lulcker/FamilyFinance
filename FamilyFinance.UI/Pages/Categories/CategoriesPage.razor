@page "/categories"

@layout MainContainerLayout

<PageTitle>FamilyFinance | Категории</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">
    Категории
</MudText>

@if (categories.Count == 0 && !isDataLoading)
{
    <MudText Typo="Typo.h5" Class="mb-3">
        Нет категорий
    </MudText>
}

@if (!isAddedMode)
{
    <MudButton OnClick="SetAddedMode"
               StartIcon="@Icons.Material.Filled.Add"
               Color="Color.Primary" Class="mb-3"
               Variant="Variant.Outlined">
        Добавить
    </MudButton>
}
else
{
    <MudPaper Class="pa-4 mb-3">
        <MudTextField Label="Название категории"
                      @bind-Value="newCategoryName"
                      Variant="Variant.Outlined" Immediate
                      Class="mb-4" AutoFocus
                      OnKeyDown="HandleKeyDown" />
        
        <MudNumericField Label="Месячный план"
                         @bind-Value="newCategoryMonthlyPlan"
                         Variant="Variant.Outlined" Immediate
                         Class="mb-4" Min="0"
                         OnKeyDown="HandleKeyDown" />
        
        <MudTextField Label="Вспомогательное слово"
                      @bind-Value="auxiliaryWord"
                      Variant="Variant.Outlined" Immediate
                      Class="mb-4"
                      OnKeyDown="HandleKeyDownForAuxiliaryWord" />
        
        <MudButton Variant="Variant.Filled"
                   OnClick="AddAuxiliaryWord"
                   Disabled="@(auxiliaryWord.IsEmpty())"
                   Class="mb-4" Color="Color.Primary">
            Добавить
        </MudButton>
        
        @if (auxiliaryWords.Count > 0)
        {
            <MudText>
                Вспомогательные слова:
            </MudText>
            <div>
                @foreach (var word in auxiliaryWords)
                {
                    <MudChip T="string" @key="word" Variant="Variant.Text"
                             Color="Color.Primary"
                             CloseIcon="@Icons.Material.Filled.Delete"
                             OnClose="@(() => RemoveAuxiliaryWord(word))">
                        @word
                    </MudChip>
                }
            </div>
        }

        <MudStack Row AlignItems="AlignItems.Center" Class="mt-4">
            <MudButton OnClick="UnsetAndClearAddedMode"
                       Color="Color.Primary" Variant="Variant.Outlined">
                Отменить
            </MudButton>

            <MudSpacer/>

            <MudButton OnClick="SaveAsync"
                       Disabled="IsSaveButtonDisabled"
                       Color="Color.Primary" Variant="Variant.Filled">
                Сохранить
            </MudButton>
        </MudStack>

        @if (isAddLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="isAddLoading"
                               Class="mt-2"/>
        }
    </MudPaper>
}

@foreach (var category in categories)
{
    <CategoryPaper Category="category"
                   OnSave="LoadDataAsync" />
}