@page "/expenses"

@layout MainContainerLayout

<PageTitle>FamilyFinance | @(isGeneralExpenses ? "Общие" : "Личные") расходы</PageTitle>

<MudButtonGroup FullWidth OverrideStyles="false" Class="mb-3">
    <MudButton OnClick="GoToReport" Color="Color.Primary" Variant="Variant.Outlined">
        Отчёт
    </MudButton>
    <MudButton Color="Color.Primary" Variant="Variant.Filled">
        Расходы
    </MudButton>
    <MudButton OnClick="GoToIncomes" Color="Color.Primary" Variant="Variant.Outlined">
        Доходы
    </MudButton>
</MudButtonGroup>

<MudButton OnClick="OpenAddExpensesDialog"
           StartIcon="@Icons.Material.Filled.Add"
           Color="Color.Primary" Class="mb-3"
           Variant="Variant.Outlined">
    Добавить
</MudButton>

<MudRadioGroup T="bool" Value="isGeneralExpenses"
               ValueChanged="IsGeneralExpensesChange">
    <MudRadio Value="true">Общие</MudRadio>
    <MudRadio Value="false">Личные</MudRadio>
</MudRadioGroup>

<MudStack Row AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Justify="Justify.FlexStart">
    <MudText>
        Сумма расходов: <b>@expenses.Sum(i => i.Amount).FormatRubles()</b>
    </MudText> 
    
    <MudSelect T="int?" Label="Месяц" Variant="Variant.Outlined"
               Dense Value="filterByMonth" OuterClass="select-180"
               ValueChanged="FilterByMonthChangedAsync" Clearable>
        @foreach (var month in Consts.Months.Where(m => m.Key <= DateTime.UtcNow.ToLocalTime().Month))
        {
            <MudSelectItem T="int?" Value="month.Key">@month.Name</MudSelectItem>
        }
    </MudSelect>
    
    <MudSelect T="Guid?" Label="Категория" Variant="Variant.Outlined"
               Dense Value="filterByCategory" OuterClass="select-210"
               ValueChanged="FilterByCategoryChangedAsync" Clearable>
        @foreach (var category in categories)
        {
            <MudSelectItem T="Guid?" Value="category.Id">@category.Name</MudSelectItem>
        }
    </MudSelect>
</MudStack>

@if (expenses.Count == 0)
{
    <MudText Class="mt-2">
        <b>Нет расходов</b>
    </MudText>
}
else
{
    <MudDataGrid Items="expenses" Virtualize
                 RowStyleFunc="RowStyleFunc"
                 SortMode="SortMode.None"
                 Class="my-grid mt-2" Height="65vh">
        <Columns>
            <PropertyColumn Property="@(x => x.Date)" Title="Дата" CellStyle="min-width: 100px; max-width: 100px" />
            <TemplateColumn Title="Сумма" CellStyle="min-width: 115px; max-width: 115px">
                <CellTemplate>
                    <MudText Typo="Typo.body2" Style="white-space: nowrap">
                        @context.Item.Amount.FormatRubles()
                    </MudText>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="@(x => x.CategoryName)" Title="Категория" CellStyle="min-width: 150px; max-width: 150px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis" />
            <TemplateColumn Title="Комментарий" CellStyle="min-width: 285px; max-width: 285px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis">
                <CellTemplate>
                    <MudText Typo="Typo.body2" Style="max-width: 283px; min-width: 283px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis" title="@context.Item.Comment">
                        @context.Item.Comment
                    </MudText>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn CellStyle="min-width: 40px; max-width: 40px">
                <CellTemplate>
                    @{
                        var expense = context.Item!;
                    }
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense>
                        @if (userSession.UserId == context.Item.UserId)
                        {
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" Label="Редактировать"
                                         OnClick="@(() => OpenEditExpenseDialogAsync(expense))" />
                            
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" Label="Удалить"
                                           OnClick="@(() => DeleteExpenseAsync(expense.Id))"
                                           IconColor="Color.Error" />
                        }
                        else
                        {
                            <MudMenuItem Icon="@Icons.Material.Filled.DoDisturb" Label="Чужой расход"
                                         IconColor="Color.Dark" Disabled />
                        }
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

<AddExpensesDialog @ref="addExpensesDialog" Categories="categories" AfterSave="LoadDataAsync" />
<EditExpenseDialog @ref="editExpenseDialog" Categories="categories" AfterSave="LoadDataAsync" />