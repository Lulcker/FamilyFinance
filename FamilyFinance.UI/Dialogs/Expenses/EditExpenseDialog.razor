<MudDialog @bind-Visible="isOpened" Options="Options">
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Edit" />
            <MudText Typo="Typo.h6">Редактирование расхода</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="isLoading"
                               Class="mt-2"/>
        }
        
        <MudDatePicker Label="Дата расхода"
                       @bind-Date="expenseDateTime" Required
                       MaxDate="@(DateTime.UtcNow.ToLocalTime())"
                       Variant="Variant.Outlined" />

        <MudNumericField T="double?" Label="Сумма расхода"
                         @bind-Value="amount" Required
                         RequiredError="Сумма расхода обязательна"
                         Variant="Variant.Outlined"
                         Min="0" Immediate />
        
        <MudSelect T="Guid?"
                   Label="Категория" Required
                   @bind-Value="categoryId"
                   Variant="Variant.Outlined"
                   Dense Immediate Class="mt-2">
            @foreach (var c in Categories)
            {
                <MudSelectItem T="Guid?" Value="@c.Id">@c.Name</MudSelectItem>
            }
        </MudSelect>

        <MudSwitch @bind-Value="isPersonal"
                   Color="Color.Primary"
                   Class="mt-2">
            Личный
        </MudSwitch>

        <MudTextField Label="Комментарий"
                      @bind-Value="comment"
                      Variant="Variant.Outlined"
                      Immediate Class="mt-2"/>

    </DialogContent>
    <DialogActions>
        <MudStack Row AlignItems="AlignItems.Center" Class="mr-4 mb-2">
            <MudButton OnClick="@(() => Close())"
                       Variant="Variant.Outlined"
                       Color="Color.Primary">
                Отмена
            </MudButton>
            <MudButton OnClick="SaveAsync"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="IsSaveButtonDisabled">
                Сохранить
            </MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>